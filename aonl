<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AONL Contact Database</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(226, 232, 240, 0.8);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }

        .table-container {
            max-height: 500px;
            overflow-y: auto;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        select {
            appearance: none;
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
            background-position: right 0.5rem center;
            background-repeat: no-repeat;
            background-size: 1.5em 1.5em;
            padding-right: 2.5rem;
        }

        /* Dropdown Menu styling */
        .action-menu {
            display: none;
            position: absolute;
            right: 0;
            top: 100%;
            z-index: 50;
            min-width: 160px;
        }
        .action-container:hover .action-menu {
            display: block;
        }
    </style>
</head>
<body class="p-4 md:p-8">
    <div class="max-w-7xl mx-auto">
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-start justify-between mb-8 gap-4">
            <div>
                <h1 class="text-3xl font-bold text-slate-900 tracking-tight">AONL Leadership Database</h1>
                <p class="text-slate-500 mt-1">Directory of conference attendees and nursing leaders.</p>
            </div>
            <div class="flex flex-col items-end gap-2">
                <div class="flex items-center gap-2">
                    <span id="recordCount" class="bg-blue-50 text-blue-700 px-3 py-1.5 rounded-lg font-semibold text-xs border border-blue-100">
                        0 Records Loaded
                    </span>
                    <button id="importBtn" class="flex items-center gap-2 bg-slate-900 hover:bg-slate-800 text-white px-4 py-1.5 rounded-lg font-medium text-xs transition-all shadow-sm">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        Import CSV
                    </button>
                </div>
                <input type="file" id="fileInput" accept=".csv" class="hidden">
            </div>
        </div>

        <!-- Charts Row -->
        <div id="chartsContainer" class="hidden grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
            <div class="glass-card p-5 rounded-2xl">
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-4">Contacts by Account Owner</p>
                <div class="h-48">
                    <canvas id="ownerChart"></canvas>
                </div>
            </div>
            <div class="glass-card p-5 rounded-2xl">
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-4">Account Type Distribution</p>
                <div class="h-48">
                    <canvas id="typeChart"></canvas>
                </div>
            </div>
            <div class="glass-card p-5 rounded-2xl">
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-4">Top 10 Job Titles</p>
                <div class="h-48">
                    <canvas id="titleChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Dashboard Stats -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="glass-card p-5 rounded-2xl">
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Unique Accounts</p>
                <h3 id="statAccounts" class="text-2xl font-bold text-slate-800 mt-1">0</h3>
            </div>
            <div class="glass-card p-5 rounded-2xl">
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">C-Suite / CNOs</p>
                <h3 id="statCNOs" class="text-2xl font-bold text-blue-600 mt-1">0</h3>
            </div>
            <div class="glass-card p-5 rounded-2xl">
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Campaign Coverage</p>
                <h3 id="statCampaigns" class="text-2xl font-bold text-slate-800 mt-1">0</h3>
            </div>
        </div>

        <!-- Primary Search -->
        <div class="glass-card rounded-2xl p-5 mb-6">
            <div class="relative w-full">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </div>
                <input type="text" id="searchInput" placeholder="Search by name, title, company, or email..." 
                       class="block w-full pl-11 pr-4 py-4 border border-slate-200 rounded-xl leading-5 bg-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-lg transition duration-150 ease-in-out">
            </div>
        </div>

        <!-- Secondary Filters -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="glass-card p-4 rounded-xl">
                <label class="text-[10px] font-bold text-slate-400 uppercase mb-1.5 block tracking-widest">Job Title</label>
                <select id="titleFilter" class="w-full bg-white border border-slate-200 rounded-lg p-2.5 text-sm text-slate-700 focus:ring-2 focus:ring-blue-500 outline-none">
                    <option value="">All Job Titles</option>
                </select>
            </div>
            <div class="glass-card p-4 rounded-xl">
                <label class="text-[10px] font-bold text-slate-400 uppercase mb-1.5 block tracking-widest">Account Owner</label>
                <select id="ownerFilter" class="w-full bg-white border border-slate-200 rounded-lg p-2.5 text-sm text-slate-700 focus:ring-2 focus:ring-blue-500 outline-none">
                    <option value="">All Owners</option>
                </select>
            </div>
            <div class="glass-card p-4 rounded-xl">
                <label class="text-[10px] font-bold text-slate-400 uppercase mb-1.5 block tracking-widest">Account Type</label>
                <select id="typeFilter" class="w-full bg-white border border-slate-200 rounded-lg p-2.5 text-sm text-slate-700 focus:ring-2 focus:ring-blue-500 outline-none">
                    <option value="">All Types</option>
                </select>
            </div>
        </div>

        <!-- Results Table -->
        <div class="glass-card rounded-2xl overflow-hidden shadow-sm border border-slate-200">
            <div class="table-container">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50 sticky top-0 z-10">
                        <tr>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Account / Campaign</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Name</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Title</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Contact Info</th>
                            <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Owner / Type</th>
                            <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody" class="bg-white divide-y divide-slate-100">
                        <tr>
                            <td colspan="6" class="px-6 py-16 text-center text-slate-400 italic">
                                <div class="flex flex-col items-center gap-2">
                                    <svg class="w-8 h-8 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 7v10c0 2 1.5 3 3.5 3h9c2 0 3.5-1 3.5-3V7c0-2-1.5-3-3.5-3h-9C5.5 4 4 5 4 7z"></path>
                                    </svg>
                                    <span>Click "Import CSV" to populate the database.</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div id="noResults" class="hidden p-16 text-center text-slate-400">
                No matching contacts found with the current filters.
            </div>
        </div>
    </div>

    <script>
        let contacts = [];
        let charts = { owner: null, type: null, title: null };

        function parseCSV(csvText) {
            const lines = csvText.trim().split(/\r?\n/);
            if (lines.length < 2) return [];

            const headers = lines[0].split(',').map(h => h.trim().replace(/^"|"$/g, ''));
            const result = [];

            for (let i = 1; i < lines.length; i++) {
                const line = lines[i];
                if (!line) continue;

                const parts = [];
                let currentPart = '';
                let inQuotes = false;

                for (let charIndex = 0; charIndex < line.length; charIndex++) {
                    const char = line[charIndex];
                    if (char === '"') {
                        if (inQuotes && line[charIndex + 1] === '"') {
                            currentPart += '"';
                            charIndex++;
                        } else {
                            inQuotes = !inQuotes;
                        }
                    } else if (char === ',' && !inQuotes) {
                        parts.push(currentPart.trim());
                        currentPart = '';
                    } else {
                        currentPart += char;
                    }
                }
                parts.push(currentPart.trim());

                if (parts.length >= headers.length) {
                    const obj = {};
                    headers.forEach((h, index) => {
                        let value = parts[index] || '';
                        value = value.replace(/^"|"$/g, '').replace(/""/g, '"');
                        obj[h] = value;
                    });
                    result.push(obj);
                }
            }
            return result;
        }

        function handleFile(file) {
            if (!file || !file.name.endsWith('.csv')) return;

            const reader = new FileReader();
            reader.onload = (e) => {
                const text = e.target.result;
                contacts = parseCSV(text);
                updateDropdowns();
                applyFilters(); 
                document.getElementById('chartsContainer').classList.remove('hidden');
            };
            reader.readAsText(file);
        }

        function updateDropdowns() {
            const ownerSelect = document.getElementById('ownerFilter');
            const typeSelect = document.getElementById('typeFilter');
            const titleSelect = document.getElementById('titleFilter');

            const owners = [...new Set(contacts.map(c => c['Account Owner']).filter(Boolean))].sort();
            const types = [...new Set(contacts.map(c => c['Account Type']).filter(Boolean))].sort();
            const titles = [...new Set(contacts.map(c => c['Title']).filter(Boolean))].sort();

            ownerSelect.innerHTML = '<option value="">All Owners</option>';
            owners.forEach(owner => ownerSelect.innerHTML += `<option value="${owner}">${owner}</option>`);

            typeSelect.innerHTML = '<option value="">All Types</option>';
            types.forEach(type => typeSelect.innerHTML += `<option value="${type}">${type}</option>`);

            titleSelect.innerHTML = '<option value="">All Job Titles</option>';
            titles.forEach(title => titleSelect.innerHTML += `<option value="${title}">${title}</option>`);
        }

        function updateCharts(dataToChart) {
            const ownerCounts = {};
            const typeCounts = {};
            const titleCounts = {};

            dataToChart.forEach(c => {
                const owner = c['Account Owner'] || 'Unassigned';
                const type = c['Account Type'] || 'Unknown';
                const title = c['Title'] || 'No Title';
                
                ownerCounts[owner] = (ownerCounts[owner] || 0) + 1;
                typeCounts[type] = (typeCounts[type] || 0) + 1;
                titleCounts[title] = (titleCounts[title] || 0) + 1;
            });

            const sortedTitles = Object.entries(titleCounts)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 10);
            const topTitleData = Object.fromEntries(sortedTitles);

            const drawChart = (id, label, dataObj, color) => {
                if (charts[id]) charts[id].destroy();
                const ctx = document.getElementById(id + 'Chart').getContext('2d');
                charts[id] = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: Object.keys(dataObj),
                        datasets: [{
                            label: label,
                            data: Object.values(dataObj),
                            backgroundColor: color,
                            borderRadius: 6
                        }]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: { duration: 400 },
                        plugins: { 
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        return ` ${context.raw} contacts`;
                                    }
                                }
                            }
                        },
                        scales: {
                            x: { grid: { display: false }, ticks: { font: { size: 9 } } },
                            y: { 
                                grid: { display: false }, 
                                ticks: { 
                                    font: { size: 9 },
                                    callback: function(value) {
                                        const label = this.getLabelForValue(value);
                                        return label.length > 20 ? label.substr(0, 20) + '...' : label;
                                    }
                                } 
                            }
                        }
                    }
                });
            };

            drawChart('owner', 'Contacts', ownerCounts, 'rgba(59, 130, 246, 0.8)');
            drawChart('type', 'Contacts', typeCounts, 'rgba(148, 163, 184, 0.8)');
            drawChart('title', 'Contacts', topTitleData, 'rgba(34, 197, 94, 0.8)');
        }

        function applyFilters() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            const ownerFilter = document.getElementById('ownerFilter').value;
            const typeFilter = document.getElementById('typeFilter').value;
            const titleFilter = document.getElementById('titleFilter').value;

            const filtered = contacts.filter(c => {
                const matchesSearch = !searchTerm || Object.values(c).some(val => String(val).toLowerCase().includes(searchTerm));
                const matchesOwner = !ownerFilter || c['Account Owner'] === ownerFilter;
                const matchesType = !typeFilter || c['Account Type'] === typeFilter;
                const matchesTitle = !titleFilter || c['Title'] === titleFilter;
                return matchesSearch && matchesOwner && matchesType && matchesTitle;
            });

            renderTable(filtered);
            renderStats(filtered);
            updateCharts(filtered);
        }

        function renderStats(dataToStat) {
            const accounts = new Set(dataToStat.map(c => c['Account Name']));
            const cnos = dataToStat.filter(c => {
                const title = (c['Title'] || '').toLowerCase();
                return title.includes('cno') || title.includes('chief nursing officer');
            });
            const campaigns = new Set(dataToStat.map(c => c['Campaign Name']));

            document.getElementById('statAccounts').innerText = accounts.size;
            document.getElementById('statCNOs').innerText = cnos.length;
            document.getElementById('statCampaigns').innerText = campaigns.size;
            
            const total = contacts.length;
            const current = dataToStat.length;
            document.getElementById('recordCount').innerText = current === total 
                ? `${total} Records Loaded` 
                : `${current} of ${total} Matches`;
        }

        function renderTable(data) {
            const tbody = document.getElementById('tableBody');
            const noResults = document.getElementById('noResults');
            tbody.innerHTML = '';

            if (data.length === 0) {
                if (contacts.length > 0) noResults.classList.remove('hidden');
                return;
            }
            noResults.classList.add('hidden');

            data.forEach(contact => {
                const tr = document.createElement('tr');
                tr.className = 'hover:bg-slate-50 transition-colors cursor-default group';
                
                const firstName = contact['First Name'] || '';
                const lastName = contact['Last Name'] || '';
                const accountName = contact['Account Name'] || '';
                
                // LinkedIn Search Query
                const liQuery = encodeURIComponent(`site:linkedin.com/in/ "${firstName} ${lastName}" ${accountName}`);
                const liUrl = `https://www.google.com/search?q=${liQuery}`;
                
                // News Search Query
                const newsQuery = encodeURIComponent(`${accountName} news`);
                const newsUrl = `https://www.google.com/search?q=${newsQuery}&tbm=nws`;

                tr.innerHTML = `
                    <td class="px-6 py-4">
                        <div class="text-sm font-semibold text-slate-900">${accountName || 'N/A'}</div>
                        <div class="text-[10px] text-slate-400 font-medium truncate max-w-[180px] mt-0.5" title="${contact['Campaign Name']}">${contact['Campaign Name'] || ''}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm font-medium text-slate-800">${firstName} ${lastName}</div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="text-sm text-slate-600 max-w-xs overflow-hidden text-ellipsis" title="${contact['Title']}">${contact['Title'] || '-'}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <a href="mailto:${contact['Email']}" class="text-sm text-blue-600 hover:underline flex items-center gap-1 font-medium">
                            ${contact['Email'] || 'No Email'}
                        </a>
                        <div class="text-[9px] text-slate-400 mt-1 uppercase tracking-tighter">ID: ${contact['Contact ID'] || 'N/A'}</div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="text-xs text-slate-700 font-semibold">${contact['Account Owner'] || '-'}</div>
                        <div class="inline-flex mt-1 items-center px-1.5 py-0.5 rounded text-[9px] font-bold bg-slate-100 text-slate-500 uppercase tracking-wider">
                            ${contact['Account Type'] || 'Unknown'}
                        </div>
                    </td>
                    <td class="px-6 py-4 text-right relative">
                        <div class="action-container relative inline-block text-left">
                            <button class="inline-flex items-center gap-1 px-3 py-1.5 border border-slate-200 rounded-lg text-xs font-semibold text-slate-600 hover:bg-slate-50 transition-all bg-white shadow-sm">
                                Actions
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div class="action-menu glass-card rounded-xl py-2 mt-1 border border-slate-200 text-left">
                                <a href="${liUrl}" target="_blank" class="flex items-center gap-2 px-4 py-2 text-xs text-slate-700 hover:bg-blue-50 hover:text-blue-700 transition-colors">
                                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                                    Find on LinkedIn
                                </a>
                                <a href="${newsUrl}" target="_blank" class="flex items-center gap-2 px-4 py-2 text-xs text-slate-700 hover:bg-slate-50 hover:text-blue-700 transition-colors">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 2v6h6m-3 4h-6m6 4h-6"></path></svg>
                                    Account News
                                </a>
                            </div>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function init() {
            const importBtn = document.getElementById('importBtn');
            const fileInput = document.getElementById('fileInput');
            const searchInput = document.getElementById('searchInput');
            const ownerFilter = document.getElementById('ownerFilter');
            const typeFilter = document.getElementById('typeFilter');
            const titleFilter = document.getElementById('titleFilter');

            importBtn.onclick = () => fileInput.click();
            fileInput.onchange = (e) => { if (e.target.files.length) handleFile(e.target.files[0]); };

            [searchInput, ownerFilter, typeFilter, titleFilter].forEach(el => {
                el.addEventListener('input', applyFilters);
            });
        }

        window.onload = init;
    </script>
</body>
</html>
